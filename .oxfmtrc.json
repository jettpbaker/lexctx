{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "endOfLine": "lf",
  "semi": false,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 80,
  "sortTailwindcss": {
    "stylesheet": "src/app/globals.css",
    "functions": ["cn", "cva"]
  },
  "ignorePatterns": [
    ".agents/**",
    ".next/**",
    "app/.well-known/**",
    "src/app/.well-known/**",
    "out/**",
    "build/**",
    "node_modules/**"
  ]
}
